{
  "version": 2,
  "builds": [
    {
      "src": "source_code/app.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": [
          "source_code/templates/**",
          "source_code/static/**",
          "data/task_manager_data.json"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "source_code/app.py"
    }
  ]
}
